#!/usr/bin/env bash
# Pre-commit hook — fast checks on staged Go files.
#
# Install (once per clone):
#   make hooks.install
#   # or: git config core.hooksPath githooks
#
# Requires bash. Optional: golangci-lint on PATH for extra checks.
set -euo pipefail

STAGED_GO=$(git diff --cached --name-only --diff-filter=ACM -- '*.go' || true)
if [ -z "$STAGED_GO" ]; then
	exit 0
fi

printf "pre-commit: checking staged Go files ...\n"

printf "  go build ./...\n"
go build ./...

printf "  go vet ./...\n"
go vet ./...

if command -v golangci-lint &>/dev/null; then
	printf "  golangci-lint (staged files)\n"
	echo "$STAGED_GO" | xargs golangci-lint run --new-from-rev=HEAD
fi

PKGS=$(echo "$STAGED_GO" | xargs -I{} dirname {} | sort -u | sed 's|^|./|')
if [ -n "$PKGS" ]; then
	printf "  go test -short (affected packages)\n"
	echo "$PKGS" | xargs go test -short -count=1
fi

# --- Auto-update per-subcommand knowledge docs ----------------------------
if [ "${SKIP_DOC_UPDATE:-}" = "1" ]; then
	printf "  ⏭️  skipping command knowledge doc update (SKIP_DOC_UPDATE=1)\n"
else
	CHANGED_CMD_DIRS=$(git diff --cached --name-only -- 'internal/verda-cli/cmd/' \
		| grep -v 'cmd/util/' | grep -v 'cmd/cmd\.go' | grep -v 'cmd/helper\.go' \
		| sed 's|internal/verda-cli/cmd/\([^/]*\)/.*|\1|' | sort -u || true)
	if [ -n "$CHANGED_CMD_DIRS" ] && command -v claude &>/dev/null; then
		printf "  📝 updating command knowledge docs ...\n"
		claude -p "/update-command-knowledge" \
			--model sonnet \
			--dangerously-skip-permissions \
			--max-budget-usd 0.50 \
			--print 2>/dev/null || printf "  ⚠️  doc update failed (non-blocking)\n"
		# Stage any updated docs
		git diff --name-only -- 'internal/verda-cli/cmd/*/README.md' 'internal/verda-cli/cmd/*/CLAUDE.md' \
			| xargs -r git add 2>/dev/null || true
	fi
fi

printf "pre-commit: ok.\n"
